# Resend API key — get from resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Contact form — email address that receives submissions
CONTACT_TO_EMAIL=hello@yourclientdomain.com

# Contact form — verified sender address (must match a domain verified in Resend)
CONTACT_FROM_EMAIL=noreply@yourclientdomain.com

# Site URL — used for canonical URLs and OG tags (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yourclientdomain.com
